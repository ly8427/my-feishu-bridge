# ==== feishu-bridge 配置模板 ====
#
# 使用方式:
#   cp .env.example ~/.secrets/feishu-bridge.env
#   chmod 600 ~/.secrets/feishu-bridge.env
#   # 编辑 ~/.secrets/feishu-bridge.env 填写真实凭证
#
# systemd 服务会自动读取 FEISHU_ENV_FILE 环境变量。
# 如果手动启动,请 export FEISHU_ENV_FILE=~/.secrets/feishu-bridge.env
#
# ⚠️ .env 文件包含密钥,永远不要 commit 到 git。

# ---- Feishu (Lark) self-built app ----
# Open Platform > your app > Credentials & Basic Info
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Access control (REQUIRED) ----
ALLOWED_USER_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Claude auth (injected into the container) ----
# Relay 模式 (ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN) 或官方 Key (ANTHROPIC_API_KEY)。
ANTHROPIC_BASE_URL=https://www.claudeide.net/api/anthropic
ANTHROPIC_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=

# ---- OpenCode engine ----
# 默认引擎: claude。飞书 /engine opencode 可运行时切换。
ENGINE=claude
OPENCODE_API_KEY=
OPENCODE_API_URL=https://open.bigmodel.cn/api/coding/paas/v4
# OPENCODE_MODEL=zhipuai-coding-plan/glm-5.2   # 可选,覆盖默认模型
#
# OpenCode 引擎需要 opencode 的 provider 认证 (auth.json),与上面的 API_KEY 不同。
# 在容器外 (宿主机) 运行一次:  opencode auth login  → 选 Z.AI Coding Plan → 粘贴 key。
# 认证文件默认在 ~/.local/share/opencode/auth.json, docker-compose 会自动挂载进容器。

# ---- Container / workspace ----
WORKSPACE_DIR=/home/user/projects
CONTAINER_NAME=feishu-claude-agent

# ---- Behaviour ----
# 自动放行的读类工具 (逗号分隔)
SAFE_TOOLS=Read,Grep,Glob,WebSearch,WebFetch,TodoWrite,NotebookRead
# 确认卡片超时 (秒)
CONFIRM_TIMEOUT=300
